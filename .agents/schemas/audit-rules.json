{
  "version": 1,
  "audits": {
    "audit-clean-code": {
      "triggers": { "gates": ["gate1", "gate3"], "filePatterns": ["**/*"] },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-architecture": {
      "triggers": { "gates": ["gate1", "gate3"] },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-security": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "security",
          "auth",
          "vulnerability",
          "cve",
          "password",
          "encrypt"
        ],
        "filePatterns": ["**/*.lock", "**/auth/*.js", "**/crypto/*.js"]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-privacy": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["privacy", "pii", "gdpr", "cookie", "tracking"],
        "filePatterns": ["**/user-profile/**/*.js"]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-lighthouse": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": [
          "lighthouse",
          "a11y",
          "accessibility",
          "wcag",
          "ui",
          "frontend",
          "aria",
          "core web vitals",
          "lcp",
          "cls"
        ],
        "filePatterns": [
          "**/*.html",
          "**/*.css",
          "**/components/**/*.js",
          "**/frontend/**/*.js"
        ]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-devops": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["ci", "deploy", "docker", "k8s", "terraform", "workflow"],
        "filePatterns": [
          ".github/workflows/**",
          "**/Dockerfile",
          "infra/**",
          "**/*.tf"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-sre": {
      "triggers": { "gates": ["gate4"] },
      "scope": "global",
      "substitutionKeys": []
    },
    "audit-documentation": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "documentation",
          "docs",
          "readme",
          "changelog",
          "runbook",
          "stale docs"
        ],
        "filePatterns": [
          "**/*.md",
          "docs/**",
          ".agents/docs/**",
          ".agents/workflows/**"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-dependencies": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": [
          "dependency",
          "dependencies",
          "package",
          "vulnerability",
          "cve",
          "upgrade",
          "supply chain"
        ],
        "filePatterns": [
          "**/package.json",
          "**/package-lock.json",
          "**/pnpm-lock.yaml",
          "**/yarn.lock"
        ]
      },
      "scope": "cumulative",
      "substitutionKeys": []
    },
    "audit-performance": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["performance", "n+1", "hot path", "latency", "throughput"],
        "filePatterns": [".agents/scripts/**", "src/**/*.{ts,js}"]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-quality": {
      "triggers": {
        "gates": ["gate1", "gate3"],
        "keywords": ["test", "coverage", "flaky", "assertion"],
        "filePatterns": ["tests/**", "**/*.test.{ts,js}", "**/*.spec.{ts,js}"]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-seo": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": ["seo", "meta", "structured data", "schema.org", "sitemap"],
        "filePatterns": ["**/*.html", "**/sitemap*", "**/robots.txt"]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-ux-ui": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": ["ux", "ui", "design tokens", "component", "accessibility"],
        "filePatterns": [
          "**/components/**/*.{tsx,jsx,vue,svelte}",
          "**/styles/**",
          "**/*.css"
        ]
      },
      "scope": "local",
      "substitutionKeys": []
    },
    "audit-navigability": {
      "triggers": {
        "gates": ["gate2", "gate3"],
        "keywords": [
          "navigability",
          "reachability",
          "nav registry",
          "route tree"
        ]
      },
      "scope": "global",
      "substitutionKeys": []
    }
  }
}
