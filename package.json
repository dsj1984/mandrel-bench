{
  "name": "mandrel-bench",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "description": "Benchmark harness that measures the Mandrel framework's value-add over a bare-model control, across framework versions and models. Consumes published `mandrel` as a pinned dependency — the version under test.",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.1 <25"
  },
  "scripts": {
    "test": "node --test \"tests/bench/**/*.test.js\"",
    "typecheck": "echo 'no-op: plain ESM JavaScript repo, no TypeScript — lint + test are the real gates (see .github/workflows/ci.yml)'",
    "bench": "node --env-file-if-exists=.env bench/run.js",
    "janitor": "node --env-file-if-exists=.env bench/driver/janitor.js",
    "lint": "biome ci . && npm run lint:md",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\" \"!.agents/**\" \"!**/CHANGELOG.md\" \"!temp/**\"",
    "format": "biome format --write .",
    "format:check": "biome ci .",
    "prepare": "husky && node .agents/scripts/sync-claude-commands.js",
    "sync:commands": "node .agents/scripts/sync-claude-commands.js",
    "bootstrap": "node .agents/scripts/bootstrap.js",
    "quality:preview": "node .agents/scripts/quality-preview.js --changed-since HEAD",
    "quality:watch": "node .agents/scripts/quality-watch.js"
  },
  "lint-staged": {
    "*.{js,json}": "biome check --write --no-errors-on-unmatched",
    "*.md": "markdownlint-cli2 --fix"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "mandrel": "^2.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.23.1",
    "yaml": "^2.9.0"
  }
}
